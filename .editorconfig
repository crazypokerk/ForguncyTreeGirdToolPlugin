# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# General settings for all files
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 2
indent_style = space

# C# files
[*.cs]
indent_size = 4
indent_style = space

# JSON files
[*.json]
indent_size = 2
indent_style = space

# JavaScript files
[*.js]
indent_size = 2
indent_style = space

# TypeScript files
[*.ts]
indent_size = 2
indent_style = space

# CSS files
[*.css]
indent_size = 2
indent_style = space

# HTML files
[*.html]
indent_size = 2
indent_style = space

# XML files
[*.xml]
indent_size = 2
indent_style = space

# XAML files
[*.xaml]
indent_size = 2
indent_style = space

# Markdown files
[*.md]
trim_trailing_whitespace = false